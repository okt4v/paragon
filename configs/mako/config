# ── Mako notification daemon config ──────────────────────────────────────────

font=JetBrainsMono Nerd Font 12
background-color=#0f172aee
text-color=#e2e8f0
border-color=#5eead4
border-radius=8
border-size=1
padding=12,16

width=340
height=110
margin=10,10,0

default-timeout=5000
ignore-timeout=0

layer=overlay
anchor=top-right

sort=-time

[urgency=low]
border-color=#334155

[urgency=normal]
border-color=#5eead4

[urgency=high]
border-color=#f43f5e
background-color=#1e0a0a
default-timeout=0
